# Използваме официален Node.js образ
FROM node:18-alpine

# Задаваме работна директория в контейнера
WORKDIR /app

# Първо копираме само файловете за зависимостите за по-бърз кеш
COPY package*.json ./

# Инсталираме всички зависимости
RUN npm install

# Копираме целия останал програмен код
COPY . .

# Тъй като твоето приложение е React, трябва да го билднем,
# за да се създаде папката /app/build, която сървърът очаква.
RUN npm run build

# Указваме порта, на който Cloud Run ще очаква приложението да слуша.
# Google Cloud инжектира PORT автоматично в обкръжението.
ENV PORT=8080
EXPOSE 8080

# Стартираме Node.js сървъра, който сервира статичните файлове
CMD ["npm", "start"]
